{
  "manifest_version": 3,
  "name": "FusenLink — AI LinkedIn Automation",
  "version": "2.0.0",
  "description": "AI-powered LinkedIn automation: bulk actions, inbox analysis, profile review, contact extraction, and scheduled workflows. Privacy policy: https://github.com/Cklaus1/fusenlink/blob/main/PRIVACY.md",
  "author": "FusenLink",
  "homepage_url": "https://github.com/Cklaus1/fusenlink",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "FusenLink",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.bundle.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*"
      ],
      "js": ["dist/content.bundle.js"]
    }
  ],
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["dist/*"],
      "matches": ["*://*.linkedin.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}